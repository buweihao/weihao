---
import { Icon } from "astro-icon/components";
import type { Product } from "../../data/products";
import { localePath, type Locale } from "../../lib/i18n";
import { getCatalogCategories } from "../../data/catalog";

type Props = {
    products: Product[];
    currentSlug: string;
    lang: Locale;
};

const { products, currentSlug, lang } = Astro.props;
const isZh = lang === "zh";

const categories = await getCatalogCategories(lang);

const newestProducts = products
    .filter((product) => product.slug !== currentSlug)
    .slice()
    .sort((a, b) => String(b.id).localeCompare(String(a.id)))
    .slice(0, 4);
---

<aside class="hidden lg:block" aria-label={isZh ? "产品导航" : "Product navigation"}>
    <div class="sticky top-28 space-y-8">
        <section class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50">
            <div class="flex items-center justify-between bg-slate-950 px-5 py-4 text-white">
                <h2 class="text-sm font-black uppercase tracking-[0.18em]">
                    {isZh ? "产品分类" : "Categories"}
                </h2>
                <Icon name="lucide:list-filter" class="h-5 w-5 text-primary" />
            </div>
            <nav class="p-3">
                <ul class="space-y-2">
                    {categories.map((category) => (
                        <li>
                            <a
                                href={localePath(lang, `/products?type=${category.slug}`)}
                                class="group flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-bold text-slate-700 transition hover:border-primary hover:text-primary"
                            >
                                <span>{category.name}</span>
                                <Icon name="lucide:chevron-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
                            </a>
                        </li>
                    ))}
                </ul>
            </nav>
        </section>

        <section>
            <div class="mb-4 flex items-center gap-2">
                <Icon name="lucide:grid-2x2" class="h-5 w-5 text-primary" />
                <h2 class="text-base font-black uppercase tracking-wide text-slate-950">
                    {isZh ? "新品推荐" : "New products"}
                </h2>
            </div>
            <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white px-4 shadow-sm">
                {newestProducts.map((product, index) => (
                    <a
                        href={localePath(lang, `/product/${product.slug}`)}
                        class:list={[
                            "group grid grid-cols-[72px_1fr] gap-3 py-4",
                            index > 0 && "border-t border-slate-100",
                        ]}
                    >
                        <img
                            src={product.images[0]}
                            alt={product.name}
                            loading="lazy"
                            class="h-[72px] w-[72px] rounded-xl bg-slate-50 object-cover"
                        />
                        <span class="min-w-0 self-center">
                            <span class="line-clamp-2 text-sm font-bold leading-5 text-slate-800 transition group-hover:text-primary">
                                {product.name}
                            </span>
                            <span class="mt-2 inline-flex items-center gap-1 text-[10px] font-black uppercase tracking-wider text-primary">
                                {isZh ? "查看详情" : "View more"}
                                <Icon name="lucide:arrow-right" class="h-3 w-3 transition-transform group-hover:translate-x-1" />
                            </span>
                        </span>
                    </a>
                ))}
            </div>
        </section>
    </div>
</aside>
