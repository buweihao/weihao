---
import { fetchSanityAboutPage, imageUrlForContain } from "../../lib/sanity";
import { defaultLocale, isLocale, pickLocalized } from "../../lib/i18n";

const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const locale = isLocale(pathLocale) ? pathLocale : defaultLocale;
const isZh = locale === "zh";
const content = await fetchSanityAboutPage();
const description = pickLocalized(undefined, content?.companyDescriptionI18n, locale);
const images = (content?.companyImages ?? []).map((image, index) => ({
    src: imageUrlForContain(image.asset, 1600),
    alt: image.alt || (isZh ? `公司图片 ${index + 1}` : `Company image ${index + 1}`),
}));

const stats = isZh
    ? [
          { value: "10,000+", unit: "㎡", lines: ["工厂占地面积超过 10,000 平方米"] },
          { value: "100,000+", unit: "件", lines: ["6 条专业生产线", "日产量可达 100,000 件"] },
          { value: "200+", unit: "名员工", lines: ["近 200 名专业生产人员", "6,000㎡ 十万级 GMPC 洁净车间"] },
      ]
    : [
          { value: "10,000+", unit: "m²", lines: ["The factory covers more than 10,000 square meters"] },
          { value: "100,000+", unit: "pieces", lines: ["Six professional production lines", "Daily output up to 100,000 pieces"] },
          { value: "200+", unit: "employees", lines: ["Nearly 200 skilled production staff", "6,000 m² GMPC clean workshop"] },
      ];

const placeholder = isZh ? "请在 Sanity 中上传素材" : "Upload this asset in Sanity";
---

<section class="bg-white py-14 md:py-20" aria-labelledby="company-information-title">
    <div class="mx-auto max-w-6xl px-5 sm:px-6 lg:px-8">
        <header class="mb-12 text-center md:mb-16">
            <p class="text-xs font-bold uppercase tracking-[0.4em] text-primary/40">Company Information</p>
            <h1 id="company-information-title" class="mt-2 font-serif text-3xl font-bold text-[#17488d] md:text-5xl">
                {isZh ? "公司信息" : "Company Information"}
            </h1>
            <div class="mx-auto mt-5 flex max-w-md items-center gap-4 text-primary">
                <span class="h-px flex-1 bg-primary/40"></span>
                <span class="flex gap-1"><i class="h-2 w-2 rounded-full bg-primary"></i><i class="h-2 w-2 rounded-full bg-primary"></i><i class="h-2 w-2 rounded-full bg-primary"></i></span>
                <span class="h-px flex-1 bg-primary/40"></span>
            </div>
        </header>

        <div class="grid overflow-hidden rounded-sm lg:grid-cols-[2fr_1fr]">
            <div class="aspect-video min-h-64 bg-[#a9bfdc]">
                {content?.companyVideoUrl ? (
                    <video class="h-full w-full object-cover" controls preload="metadata" playsinline>
                        <source src={content.companyVideoUrl} />
                    </video>
                ) : (
                    <div class="grid h-full place-items-center text-center font-bold text-white/90">
                        <span><span class="block text-4xl">▶</span><span class="mt-3 block text-sm">{placeholder}</span></span>
                    </div>
                )}
            </div>
            <aside class="flex flex-col justify-center gap-7 bg-[#2457a6] p-7 text-white md:p-10">
                {stats.map((stat) => (
                    <div>
                        <p class="text-2xl font-black md:text-3xl">{stat.value} <span class="text-sm font-bold">{stat.unit}</span></p>
                        <ul class="mt-2 space-y-1 text-xs leading-4 text-white/90 md:text-sm">
                            {stat.lines.map((line) => <li class="flex gap-2"><span>•</span><span>{line}</span></li>)}
                        </ul>
                    </div>
                ))}
            </aside>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1.65fr_0.8fr] lg:gap-8">
            <article class="self-start py-2 lg:pr-5">
                <h2 class="text-2xl font-black text-slate-950 md:text-3xl">{isZh ? "关于公司" : "About Company"}</h2>
                <span class="mt-4 block h-1 w-14 bg-slate-950"></span>
                <p class="mt-6 whitespace-pre-line text-base leading-8 text-slate-700">
                    {description || placeholder}
                </p>
            </article>
            <div class="grid gap-5">
                {[0, 1].map((index) => (
                    images[index]?.src ? (
                        <img src={images[index].src} alt={images[index].alt} class="aspect-[4/3] h-full w-full bg-slate-100 object-cover" />
                    ) : (
                        <div class="grid aspect-[4/3] place-items-center bg-slate-100 text-xs font-bold text-slate-400">{placeholder}</div>
                    )
                ))}
            </div>
        </div>

        <div class="mt-6 grid gap-6 lg:grid-cols-[1.65fr_0.8fr] lg:gap-8">
            {images[2]?.src ? (
                <img src={images[2].src} alt={images[2].alt} class="aspect-[16/8] h-full w-full bg-slate-100 object-cover" />
            ) : (
                <div class="grid aspect-[16/8] place-items-center bg-slate-100 text-xs font-bold text-slate-400">{placeholder}</div>
            )}
            {images[3]?.src ? (
                <img src={images[3].src} alt={images[3].alt} class="aspect-[4/3] h-full w-full bg-slate-100 object-cover" />
            ) : (
                <div class="grid aspect-[4/3] place-items-center bg-slate-100 text-xs font-bold text-slate-400">{placeholder}</div>
            )}
        </div>
    </div>
</section>
