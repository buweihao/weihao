---
import { Icon } from "astro-icon/components";
import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";
import { fetchSanityAboutCompanyCarousel, imageSrcSetForContain, imageUrlForContain } from "../../lib/sanity";
import { defaultLocale, isLocale } from "../../lib/i18n";

const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const locale = isLocale(pathLocale) ? pathLocale : defaultLocale;
const isZh = locale === "zh";
const content = await fetchSanityAboutCompanyCarousel();
const images = (content?.images ?? [])
    .map((image, index) => ({
        src: imageUrlForContain(image.asset, 1000),
        srcset: imageSrcSetForContain(image.asset, [360, 640, 1000]),
        alt: isZh ? `公司展示图片 ${index + 1}` : `Company showcase image ${index + 1}`,
    }))
    .filter((image): image is { src: string; srcset: string | undefined; alt: string } => Boolean(image.src));
---

{images.length > 0 && (
    <section class="overflow-hidden bg-white py-14 md:py-20" aria-labelledby="our-company-title">
        <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
            <header class="mb-10 text-center md:mb-14">
                <p class="text-xs font-bold uppercase tracking-[0.4em] text-primary/35">Our Company</p>
                <h2 id="our-company-title" class="mt-2 font-serif text-3xl font-bold uppercase text-[#17488d] md:text-5xl">
                    {isZh ? "我们的公司" : "Our Company"}
                </h2>
                <div class="mx-auto mt-5 flex max-w-md items-center gap-4 text-primary">
                    <span class="h-px flex-1 bg-primary/40"></span>
                    <span class="flex gap-1"><i class="h-2 w-2 rounded-full bg-primary"></i><i class="h-2 w-2 rounded-full bg-primary"></i><i class="h-2 w-2 rounded-full bg-primary"></i></span>
                    <span class="h-px flex-1 bg-primary/40"></span>
                </div>
            </header>

            <div class="swiper about-company-swiper" data-slide-count={images.length}>
                <div class="swiper-wrapper">
                    {images.map((image) => (
                        <div class="swiper-slide h-auto overflow-hidden bg-[#edf3fb]">
                            <img src={image.src} srcset={image.srcset} sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 88vw" alt={image.alt} loading="lazy" decoding="async" class="aspect-[4/3] h-full w-full object-cover" />
                        </div>
                    ))}
                </div>
                {images.length > 1 && (
                    <>
                        <button type="button" class="about-company-prev absolute left-2 top-1/2 z-10 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-primary shadow-lg transition hover:bg-white" aria-label={isZh ? "上一张" : "Previous slide"}>
                            <Icon name="lucide:chevron-left" class="h-5 w-5" />
                        </button>
                        <button type="button" class="about-company-next absolute right-2 top-1/2 z-10 grid h-10 w-10 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-primary shadow-lg transition hover:bg-white" aria-label={isZh ? "下一张" : "Next slide"}>
                            <Icon name="lucide:chevron-right" class="h-5 w-5" />
                        </button>
                        <div class="about-company-pagination mt-7 text-center"></div>
                    </>
                )}
            </div>
        </div>
    </section>
)}

<script>
    import Swiper from "swiper";
    import { Autoplay, Navigation, Pagination } from "swiper/modules";

    const initCompanyCarousel = () => {
        document.querySelectorAll<HTMLElement>(".about-company-swiper:not([data-initialized])").forEach((element) => {
            const count = Number(element.dataset.slideCount ?? 0);
            element.dataset.initialized = "true";
            new Swiper(element, {
                modules: [Autoplay, Navigation, Pagination],
                slidesPerView: 1.12,
                spaceBetween: 16,
                speed: 700,
                rewind: true,
                autoplay: count > 1 ? { delay: 3000, disableOnInteraction: false, pauseOnMouseEnter: true } : false,
                navigation: { nextEl: element.querySelector<HTMLElement>(".about-company-next"), prevEl: element.querySelector<HTMLElement>(".about-company-prev") },
                pagination: { el: element.querySelector<HTMLElement>(".about-company-pagination"), clickable: true },
                breakpoints: {
                    640: { slidesPerView: 2, spaceBetween: 20 },
                    1024: { slidesPerView: 4, spaceBetween: 22 },
                },
            });
        });
    };

    initCompanyCarousel();
    document.addEventListener("astro:after-swap", initCompanyCarousel);
</script>

<style is:global>
    .about-company-pagination .swiper-pagination-bullet-active { width: 24px; border-radius: 999px; background: #2457a6; }
</style>
