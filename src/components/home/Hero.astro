---
import { Icon } from "astro-icon/components";
import { getHeroSlides } from "../../data/catalog";
import { defaultLocale, isLocale } from "../../lib/i18n";

const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const currentLocale = isLocale(pathLocale) ? pathLocale : defaultLocale;
const slides = await getHeroSlides(currentLocale);
---

<section class="relative w-full overflow-hidden">
    <!-- Swiper Container -->
    <div class="swiper hero-swiper h-[350px] sm:h-[450px] md:h-[500px]">
        <div class="swiper-wrapper">
            {
                slides.map((slide) => (
                    <div class="swiper-slide relative">
                        <img
                            src={slide.image}
                            alt={slide.alt}
                            class="absolute inset-0 w-full h-full object-contain"
                        />
                        <div
                            class:list={[
                                "absolute inset-0 px-4 md:px-24",
                                slide.align === "left"
                                    ? "bg-linear-to-r from-black/60 to-transparent flex items-center justify-start"
                                    : "bg-black/45 flex items-center justify-center text-center",
                            ]}
                        >
                            <div
                                class:list={[
                                    "animate-fade-in",
                                    slide.align === "left" ? "max-w-2xl text-left" : "max-w-3xl",
                                ]}
                            >
                                {slide.eyebrow && (
                                    <span class="badge badge-primary mb-4 p-4 font-bold uppercase tracking-widest">
                                        {slide.eyebrow}
                                    </span>
                                )}
                                <h2 class="text-4xl md:text-6xl font-bold text-white mb-4 tracking-tight">
                                    {slide.title}
                                </h2>
                                <p
                                    class:list={[
                                        "text-lg md:text-xl text-white/90 mb-8",
                                        slide.align === "left" ? "" : "max-w-xl mx-auto",
                                    ]}
                                >
                                    {slide.description}
                                </p>
                                <div
                                    class:list={[
                                        "flex flex-wrap gap-4",
                                        slide.align === "left" ? "justify-start" : "justify-center",
                                    ]}
                                >
                                    <a
                                        href={slide.primaryHref}
                                        class="btn btn-primary btn-lg rounded-full px-8 shadow-xl hover:scale-105 transition-transform"
                                    >
                                        {slide.primaryLabel}
                                    </a>
                                    {slide.secondaryLabel && slide.secondaryHref && (
                                        <a
                                            href={slide.secondaryHref}
                                            class="btn btn-outline btn-white btn-lg rounded-full px-8 text-white hover:bg-white hover:text-black transition-all"
                                        >
                                            {slide.secondaryLabel}
                                        </a>
                                    )}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- Navigation -->
        <div
            class="hero-next text-white! w-10 h-10 hover:scale-110 transition-transform hidden sm:flex items-center justify-center bg-black/20 hover:bg-black/40 rounded-full cursor-pointer absolute right-4 top-1/2 -translate-y-1/2 z-50"
        >
            <Icon name="lucide:chevron-right" class="w-6 h-6" />
        </div>
        <div
            class="hero-prev text-white! w-10 h-10 hover:scale-110 transition-transform hidden sm:flex items-center justify-center bg-black/20 hover:bg-black/40 rounded-full cursor-pointer absolute left-4 top-1/2 -translate-y-1/2 z-50"
        >
            <Icon name="lucide:chevron-left" class="w-6 h-6" />
        </div>

        <!-- Pagination -->
        <div class="swiper-pagination bottom-8!"></div>
    </div>
</section>

<!-- Swiper Styles -->
<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>

<style>
    /* Custom Swiper Pagination Colors */
    :root {
        --swiper-pagination-color: var(--color-primary);
        --swiper-pagination-bullet-inactive-color: #fff;
        --swiper-pagination-bullet-inactive-opacity: 0.5;
        --swiper-pagination-bullet-size: 10px;
        --swiper-pagination-bullet-horizontal-gap: 6px;
    }

    .swiper-pagination-bullet-active {
        width: 24px;
        border-radius: 5px;
        transition: width 0.3s ease;
    }

    @keyframes fade-in {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in {
        animation: fade-in 1s ease-out forwards;
    }
</style>

<script>
    import Swiper from "swiper";
    import {
        Navigation,
        Pagination,
        Autoplay,
        EffectFade,
    } from "swiper/modules";

    const initHeroSwiper = () => {
        new Swiper(".hero-swiper", {
            modules: [Navigation, Pagination, Autoplay, EffectFade],
            loop: true,
            effect: "fade",
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
            },
            pagination: {
                el: ".swiper-pagination",
                clickable: true,
            },
            navigation: {
                nextEl: ".hero-next",
                prevEl: ".hero-prev",
            },
        });
    };

    // Initialize on load and after view transitions
    initHeroSwiper();
    document.addEventListener("astro:after-swap", initHeroSwiper);
</script>
