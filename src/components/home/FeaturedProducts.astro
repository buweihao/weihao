---
import { getCatalogProducts } from "../../data/catalog";
import CardProduct from "../products/CardProduct.astro";
import { defaultLocale, isLocale, type Locale } from "../../lib/i18n";

const MAX_HOT_PRODUCTS = 12;
const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const currentLocale: Locale = isLocale(pathLocale) ? pathLocale : defaultLocale;
const products = (await getCatalogProducts(currentLocale)).slice(0, MAX_HOT_PRODUCTS);
---

<section class="py-12 md:py-16 bg-base-100" id="hot-products-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10">
            <div>
                <p class="mb-2 text-xs font-black uppercase tracking-[0.28em] text-primary">
                    {currentLocale === "zh" ? "人气推荐" : "Customer Favorites"}
                </p>
                <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter">
                    {currentLocale === "zh" ? "热门产品" : "Hot Products"}
                </h2>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
            {products.map((product) => (
                <CardProduct
                    title={product.title}
                    price={product.price}
                    stock={product.stock}
                    images={product.images}
                    slug={product.slug}
                />
            ))}
        </div>
    </div>
</section>
