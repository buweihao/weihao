---

---

<form class="w-full" id="contact-form" action="/api/contact" method="post">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- First Name -->
        <div class="flex flex-col">
            <label for="firstName" class="font-semibold text-[#0B2545] mb-2">
                First Name
            </label>
            <input
                type="text"
                id="firstName"
                name="firstName"
                placeholder="Your first name"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
                required
            />
        </div>

        <!-- Last Name -->
        <div class="flex flex-col">
            <label for="lastName" class="font-semibold text-[#0B2545] mb-2">
                Last Name
            </label>
            <input
                type="text"
                id="lastName"
                name="lastName"
                placeholder="Your last name"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
                required
            />
        </div>

        <!-- Email -->
        <div class="flex flex-col">
            <label for="email" class="font-semibold text-[#0B2545] mb-2">
                Email
            </label>
            <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
                required
            />
        </div>

        <!-- Phone -->
        <div class="flex flex-col">
            <label for="phone" class="font-semibold text-[#0B2545] mb-2">
                Phone
            </label>
            <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+1 555-555-5555"
                class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]"
            />
        </div>
    </div>

    <!-- Message -->
    <div class="flex flex-col mt-6">
        <label for="message" class="font-semibold text-[#0B2545] mb-2">
            Message
        </label>
        <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Write your inquiry here..."
            class="border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F9C74F] resize-none"
            required></textarea>
    </div>

    <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
    <input type="hidden" name="sourceUrl" value="" />

    <!-- Button -->
    <div class="text-center md:text-right mt-8">
        <button
            type="submit"
            id="contact-submit"
            class="bg-primary text-primary-content hover:bg-primary/90 font-bold px-12 py-4 rounded-full cursor-pointer transition text-lg shadow-lg hover:shadow-xl hover:scale-105 transform duration-200"
        >
            Send Message
        </button>
    </div>

    <p id="contact-status" class="mt-4 text-sm font-semibold text-slate-600" role="status">
    </p>
</form>

<script>
    function initContactForm() {
        const form = document.getElementById("contact-form") as HTMLFormElement | null;
        const status = document.getElementById("contact-status");
        const submit = document.getElementById("contact-submit") as HTMLButtonElement | null;

        if (!form || form.dataset.ready) return;
        form.dataset.ready = "true";

        const sourceUrl = form.querySelector('input[name="sourceUrl"]') as HTMLInputElement | null;
        if (sourceUrl) sourceUrl.value = window.location.href;

        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            if (!submit || !status) return;

            submit.disabled = true;
            status.textContent = "Sending...";
            status.className = "mt-4 text-sm font-semibold text-slate-600";

            const formData = new FormData(form);
            const firstName = String(formData.get("firstName") || "").trim();
            const lastName = String(formData.get("lastName") || "").trim();

            const payload = {
                name: [firstName, lastName].filter(Boolean).join(" "),
                email: formData.get("email"),
                phone: formData.get("phone"),
                message: formData.get("message"),
                website: formData.get("website"),
                sourceUrl: formData.get("sourceUrl"),
            };

            try {
                const response = await fetch(form.action, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                });
                const result = await response.json().catch(() => ({}));

                if (!response.ok || !result.ok) {
                    throw new Error(result.error || "Unable to send message");
                }

                form.reset();
                status.textContent = "Message sent. We will reply shortly.";
                status.className = "mt-4 text-sm font-semibold text-emerald-600";
            } catch (error) {
                status.textContent =
                    error instanceof Error ? error.message : "Unable to send message";
                status.className = "mt-4 text-sm font-semibold text-red-600";
            } finally {
                submit.disabled = false;
            }
        });
    }

    initContactForm();
    document.addEventListener("astro:page-load", initContactForm);
</script>
