---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import ProductGallery from "../../components/products/ProductGallery.astro";
import ProductInfo from "../../components/products/ProductInfo.astro";
import ProductDetailInquiry from "../../components/products/ProductDetailInquiry.astro";
import ProductSidebar from "../../components/products/ProductSidebar.astro";
import CardProduct from "../../components/products/CardProduct.astro";
import {
    getCatalogProducts,
    getRelatedProductsFromList,
} from "../../data/catalog";
import { defaultLocale, localePath } from "../../lib/i18n";

export async function getStaticPaths() {
    const products = await getCatalogProducts(defaultLocale);

    return products.map((product) => ({
        params: { slug: product.slug },
        props: { product },
    }));
}

const { product } = Astro.props;
const products = await getCatalogProducts(defaultLocale);
const relatedProducts = getRelatedProductsFromList(
    products,
    product.category,
    product.slug,
);

const breadcrumbItems = [
    { label: "Home", href: localePath(defaultLocale, "/") },
    {
        label: product.category,
        href: localePath(defaultLocale, `/products?type=${product.categorySlug}`),
    },
    { label: product.name },
];
---

<Layout title={`${product.name} | E-COMMER`}>
    <div class="bg-white min-h-screen pb-20 pt-10">
        <div class="max-w-7xl mx-auto px-6">
            <Breadcrumbs items={breadcrumbItems} />
        </div>

        <main class="max-w-7xl mx-auto px-6 py-12 md:py-16">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20">
                <ProductGallery images={product.images} />
                <ProductInfo product={product} />
            </div>

            <div class="mt-24 grid grid-cols-1 lg:grid-cols-[280px_minmax(0,1fr)] xl:grid-cols-[300px_minmax(0,1fr)] gap-10 xl:gap-14 items-start">
                <ProductSidebar products={products} currentSlug={product.slug} lang={defaultLocale} />
                <div class="min-w-0 [&>section:first-child]:mt-0 [&>section:first-child]:pt-0 [&>section:first-child]:border-t-0">
                    <ProductDetailInquiry
                        productName={product.name}
                        productDetail={product.productDetail}
                    />

                </div>
            </div>

            <section class="mt-24 border-t border-slate-200 pt-14">
                <div class="mb-10 flex items-center justify-between border-b border-slate-100 pb-6">
                    <h2 class="text-2xl md:text-3xl font-black text-slate-950 uppercase tracking-tight">
                        You may also <span class="text-primary">like</span>
                    </h2>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                    {relatedProducts.map((relProduct) => (
                        <CardProduct title={relProduct.name} price={relProduct.price} images={relProduct.images} stock={relProduct.stock} slug={relProduct.slug} />
                    ))}
                </div>
            </section>
        </main>
    </div>
</Layout>

<style>
    /* Add some premium spacing and transitions */
    main {
        animation: fadeIn 0.8s ease-out;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
