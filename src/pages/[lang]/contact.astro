---
import { defaultLocale, isLocale, ui } from "../../lib/i18n";
import { getSiteSettings } from "../../data/siteSettings";

const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const currentLocale = isLocale(pathLocale) ? pathLocale : defaultLocale;
const copy = ui[currentLocale].contactPage;
const siteSettings = await getSiteSettings(currentLocale);

import Layout from "../../layouts/Layout.astro";
import FormContact from "../../components/contact/FormContact.astro";
import ContactInfo from "../../components/contact/ContactInfo.astro";
import SocialFollow from "../../components/contact/SocialFollow.astro";
import { locales } from "../../lib/i18n";

export function getStaticPaths() {
    return locales.map((lang) => ({ params: { lang } }));
}
---

<Layout>
    <section class="max-w-7xl mx-auto px-4 py-16 lg:py-24">
        <h2
            class="text-3xl md:text-5xl font-black text-center uppercase tracking-tighter mb-16"
        >
            {copy.title1}<span class="text-primary">{copy.title2}</span>
        </h2>

        <div class="flex flex-col lg:flex-row items-start gap-12 lg:gap-20">
            <div class="w-full lg:w-4/12 flex flex-col justify-center">
                <div class="prose prose-lg mb-10">
                    <p
                        class="text-xl md:text-2xl font-medium text-base-content leading-relaxed"
                    >
                        {siteSettings.contactSubtitle}
                    </p>
                </div>

                <ContactInfo />
                <SocialFollow />
            </div>

            <div class="w-full lg:w-8/12">
                <FormContact />
            </div>
        </div>
    </section>
</Layout>
