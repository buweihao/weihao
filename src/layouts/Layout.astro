---
import "../styles/global.css";
import Navbar from "../components/navbar/NavBar.astro";
import AnnouncementBar from "../components/ui/AnnouncementBar.astro";
import Footer from "../components/footer/Footer.astro";
import ToasterComponent from "../components/ui/ToasterComponent";
import CartDrawer from "../components/cart/CartDrawer.astro";
import FloatingContact from "../components/contact/FloatingContact.astro";
import {
	alternateLinks,
	defaultLocale,
	isLocale,
	localeHtmlLang,
	localePath,
	stripLocale,
	ui,
} from "../lib/i18n";

const { title, description } = Astro.props;
const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const currentLocale = isLocale(pathLocale) ? pathLocale : defaultLocale;
const copy = ui[currentLocale];
const pageTitle = title ?? copy.siteTitle;
const pageDescription =
	description ?? "A premium ecommerce inquiry template with Sanity-powered content.";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const alternates = alternateLinks(Astro.url.pathname).map((item) => ({
	...item,
	href: new URL(item.href, Astro.site ?? Astro.url.origin).href,
}));
const xDefaultUrl = new URL(
	localePath(defaultLocale, stripLocale(Astro.url.pathname)),
	Astro.site ?? Astro.url.origin,
).href;
---

<!doctype html>
<html lang={localeHtmlLang[currentLocale]} data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={canonicalUrl.href} />
		{alternates.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}
		<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
	</head>
	<body class="bg-base-200 min-h-screen">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[1000] focus:rounded-full focus:bg-base-100 focus:px-4 focus:py-2 focus:text-sm"
		>
			{copy.skip}
		</a>
		<AnnouncementBar currentLocale={currentLocale} />
		<Navbar currentLocale={currentLocale} currentPath={Astro.url.pathname} />
		<main id="main-content">
			<slot />
		</main>
		<Footer currentLocale={currentLocale} />
		<FloatingContact />
		<CartDrawer />
		<ToasterComponent client:load />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
	}
</style>
